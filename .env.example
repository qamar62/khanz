# Khanz Restaurant - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=khanz_db
POSTGRES_USER=khanz_user
POSTGRES_PASSWORD=your_strong_password_here

# ============================================
# DJANGO BACKEND CONFIGURATION
# ============================================
DEBUG=False
DJANGO_SECRET_KEY=your-super-secret-key-generate-a-random-one

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# CORS allowed origins (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# ============================================
# GOOGLE CALENDAR INTEGRATION
# ============================================
GOOGLE_CALENDAR_ENABLED=True
GOOGLE_CALENDAR_ID=primary

# NOTE: Place credentials.json and token.json in backend/ directory
# These files are gitignored for security

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Khanz Restaurant <noreply@yourdomain.com>

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For production, update to:
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ============================================
# NOTES
# ============================================
# 1. NEVER commit .env file to git
# 2. Generate a strong SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 3. For Gmail, use App Password: https://myaccount.google.com/apppasswords
# 4. Keep credentials.json and token.json secure and never commit them
